{
  "overrides": [
    {
      "files": ["*.html"],
      "options": {
        "parser": "html",
        "printWidth": 120,
        "tabWidth": 4
      }
    },
    {
      "files": ["*.css"],
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": ["*.js"],
      "options": {
        "tabWidth": 4
      }
    }
  ]
}
